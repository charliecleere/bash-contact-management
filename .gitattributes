# Auto-detect text files and normalize line endings to LF
* text=auto

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Text files
*.txt text eol=lf
*.md text eol=lf
LICENSE text eol=lf

# Git config
.gitignore text eol=lf
.gitattributes text eol=lf

# Data files
*.contacts text eol=lf

# Binary files
*.exe binary
*.bin binary
